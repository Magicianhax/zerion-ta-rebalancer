# The Claude Agent SDK declares zod ^4 as a peer, but the rest of this
# codebase still uses zod 3 syntax (see src/api/routes/*.ts). The SDK's
# transitive constraint via @anthropic-ai/sdk is actually ^3.25 || ^4,
# so zod 3 works fine at runtime — only the strict peer check fails.
# Bumping zod to 4 would require rewriting every z.X schema; not worth it.
legacy-peer-deps=true
