# --- Required ---

# Zerion API key — get one at https://dashboard.zerion.io
ZERION_API_KEY=zk_...

# Password for the web dashboard (used as bearer token)
ADMIN_PASSWORD=change-me-please

# Path to the forked Zerion CLI (relative or absolute)
ZERION_CLI_PATH=../zerion-ai/cli/zerion.js

# --- Optional ---

# Server port (default: 3000)
PORT=3000

# Telegram bot token from @BotFather (optional — leave empty to disable bot)
TELEGRAM_BOT_TOKEN=

# Cron schedule for auto-rebalance (default: every hour at :00)
REBALANCE_CRON=0 * * * *

# Default chain for new baskets: solana | base
DEFAULT_CHAIN=solana

# --- Security model (read this) ---
#
# This file holds NO key material. It never asks for your wallet passphrase.
#
#   • Passphrase  — typed interactively during `npm run setup`, only consumed
#                   by OWS to encrypt the wallet at rest. We never see it.
#   • Agent token — auto-saved by the Zerion CLI to ~/.zerion/config.json
#                   after `agent create-token`. Bound to a policy, scoped to
#                   what the policy allows. This is what the bot uses to
#                   sign — no passphrase prompt at runtime.
#
# If anyone ever asks you to put a wallet passphrase in this file, they are
# wrong.

# --- Advanced ---

# SQLite DB path (default: ./data/rebalancer.db)
DB_PATH=./data/rebalancer.db

# Maximum drift per rebalance, % (default: 10)
MAX_DRIFT_PERCENT=10

# Cooldown between rebalances, minutes (default: 45)
REBALANCE_COOLDOWN_MINUTES=45

# Default slippage tolerance, % (default: 2)
DEFAULT_SLIPPAGE=2
