# --- Required ---

# Zerion API key — get one at https://dashboard.zerion.io
ZERION_API_KEY=zk_...

# Password for the web dashboard (used as bearer token)
ADMIN_PASSWORD=change-me-please

# Path to the forked Zerion CLI (relative or absolute)
ZERION_CLI_PATH=../zerion-ai/cli/zerion.js

# --- Optional ---

# Server port (default: 3000)
PORT=3000

# Telegram bot token from @BotFather (optional — leave empty to disable bot)
TELEGRAM_BOT_TOKEN=

# Cron schedule for auto-rebalance (default: every hour at :00)
REBALANCE_CRON=0 * * * *

# Default chain for new baskets: solana | base
DEFAULT_CHAIN=solana

# --- Claude Agent (reasoning + Telegram chat) ---
#
# The agent uses the Claude Agent SDK — the same SDK that powers Claude Code.
# Authentication priority:
#
#   1. ANTHROPIC_API_KEY below     → direct API billing (per-token cost)
#   2. Claude Code subscription    → free if you have a Pro/Team/Max plan and
#      ran `claude login` on this machine. Reads ~/.claude/.credentials.json.
#   3. Neither                     → agent disabled. Cron falls back to
#      deterministic rebalances; bot tells the user chat is off.
#
# For your own self-hosted personal copy, leaving ANTHROPIC_API_KEY empty and
# using your Claude Code subscription is cheapest — no extra billing.
# For distributed / production deployments, set ANTHROPIC_API_KEY.

ANTHROPIC_API_KEY=

# Model — pick by cost vs intelligence:
#   claude-opus-4-7    — most capable, best for autonomous decisions
#   claude-sonnet-4-6  — balanced, recommended starting point (default)
#   claude-haiku-4-5   — fastest, cheapest, fine for chat replies
ANTHROPIC_MODEL=claude-sonnet-4-6

# Agent effort: low | medium | high (xhigh and max are Opus-only).
# Higher = more thinking + tool calls per tick = better decisions but more cost.
# Currently informational only — the SDK manages effort internally.
AGENT_EFFORT=medium

# --- Security model (read this) ---
#
# This file holds NO key material. It never asks for your wallet passphrase.
#
#   • Passphrase  — typed interactively during `npm run setup`, only consumed
#                   by OWS to encrypt the wallet at rest. We never see it.
#   • Agent token — auto-saved by the Zerion CLI to ~/.zerion/config.json
#                   after `agent create-token`. Bound to a policy, scoped to
#                   what the policy allows. This is what the bot uses to
#                   sign — no passphrase prompt at runtime.
#
# If anyone ever asks you to put a wallet passphrase in this file, they are
# wrong.

# --- Advanced ---

# SQLite DB path (default: ./data/rebalancer.db)
DB_PATH=./data/rebalancer.db

# Maximum drift per rebalance, % (default: 10)
MAX_DRIFT_PERCENT=10

# Cooldown between rebalances, minutes (default: 45)
REBALANCE_COOLDOWN_MINUTES=45

# Default slippage tolerance, % (default: 2)
DEFAULT_SLIPPAGE=2
