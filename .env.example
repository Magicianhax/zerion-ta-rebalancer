# ════════════════════════════════════════════════════════════════════
#  Zerion TA Rebalancer · environment configuration
# ════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in the REQUIRED section. Everything
# below the SECURITY MODEL note is optional with sensible defaults.
#
# ──────────────────────────────────────────────────────────────────
#  REQUIRED — the app refuses to boot without these
# ──────────────────────────────────────────────────────────────────

# Zerion API key. Free tier is plenty.
#   → https://dashboard.zerion.io
ZERION_API_KEY=zk_...

# Password for the web dashboard. Min 8 chars.
# Also used as the bearer token for API calls — pick something strong.
ADMIN_PASSWORD=change-me-please

# Path to the forked Zerion CLI's entry point. Default works if you
# cloned `zerion-ai` as a sibling of this repo (see README → Install).
ZERION_CLI_PATH=../zerion-ai/cli/zerion.js


# ──────────────────────────────────────────────────────────────────
#  TELEGRAM (optional — leave both empty to disable the bot)
# ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to talk to the bot.
# The bot ignores everyone else. Find your numeric ID by messaging
# @userinfobot — it replies with something like 5800688332.
# Leave empty for full lockdown (bot answers no one).
#
# Example: TELEGRAM_AUTHORIZED_USER_IDS=5800688332,123456789
TELEGRAM_AUTHORIZED_USER_IDS=


# ──────────────────────────────────────────────────────────────────
#  CLAUDE AGENT (reasoning + Telegram chat)
# ──────────────────────────────────────────────────────────────────
#
# The agent uses the Claude Agent SDK. Authentication priority:
#
#   1. ANTHROPIC_API_KEY below       → direct API billing (per-token)
#   2. Claude Code subscription      → free if you have a Pro/Team/Max
#      plan AND ran `claude login` on this machine
#   3. Neither                       → agent disabled. Cron still
#      fires deterministic rebalances; the bot answers /balance,
#      /pause, /resume, /status but not free-form chat.
#
# For self-hosted personal use, leave ANTHROPIC_API_KEY empty and use
# your Claude Code subscription. For shared deployments, set the key.

ANTHROPIC_API_KEY=

# Model:
#   claude-opus-4-7    — most capable, best for autonomous decisions
#   claude-sonnet-4-6  — balanced (default)
#   claude-haiku-4-5   — cheapest, fine for chat-only use
ANTHROPIC_MODEL=claude-sonnet-4-6

# Reasoning effort: low | medium | high (xhigh and max are Opus-only).
# Higher = more thinking + tool calls per tick. Currently informational —
# the SDK handles its own thinking budget.
AGENT_EFFORT=medium


# ──────────────────────────────────────────────────────────────────
#  RUNTIME (optional — defaults are sensible)
# ──────────────────────────────────────────────────────────────────

# Web server port.
PORT=3000

# Default chain for new baskets: solana | base
DEFAULT_CHAIN=solana

# Cron schedule for auto-rebalance (top of every hour by default).
REBALANCE_CRON=0 * * * *

# SQLite database file.
DB_PATH=./data/rebalancer.db


# ──────────────────────────────────────────────────────────────────
#  TUNING (rarely touched)
# ──────────────────────────────────────────────────────────────────

# Largest single-token weight shift allowed per rebalance (%).
# Auto-skipped on a basket's first allocation.
MAX_DRIFT_PERCENT=10

# Minimum minutes between rebalances on the same basket.
REBALANCE_COOLDOWN_MINUTES=45

# Slippage tolerance on every swap (%). Values higher than this get
# rejected upstream and logged.
DEFAULT_SLIPPAGE=2


# ════════════════════════════════════════════════════════════════════
#  SECURITY MODEL — please read
# ════════════════════════════════════════════════════════════════════
#
# This file holds NO key material. There is no wallet passphrase here.
#
#   • Passphrase   — typed interactively during `npm run setup`. Used
#                    by OWS to encrypt the keystore at rest. Never
#                    leaves the wizard.
#   • Agent token  — auto-saved by the Zerion CLI to ~/.ows/ after
#                    `agent create-token`. Bound to a policy; can only
#                    sign the kinds of transactions the policy allows.
#                    This is what the rebalancer uses at runtime.
#
# If anyone ever asks you to put a wallet passphrase in this file, they
# are wrong.
