# ════════════════════════════════════════════════════════════════════
#  Zerion TA Rebalancer · voice frontend (Raspberry Pi)
# ════════════════════════════════════════════════════════════════════
#
# This .env lives on the Pi. The rebalancer's own .env lives on the
# strong Linux box that runs Node + Claude. The Pi only needs:
#   • where the rebalancer is
#   • how to authenticate to it
#   • voice provider credentials
#
# Copy to `.env` and fill in.

# ── Rebalancer backend ─────────────────────────────────────────────

# URL where the rebalancer's HTTP API is reachable from the Pi.
# Example: http://192.168.100.71:8080
REBALANCER_URL=

# Same value as ADMIN_PASSWORD on the rebalancer's .env.
# Used as the Bearer token for the API + the ?token= for the SSE stream.
REBALANCER_TOKEN=

# ── Voice provider keys ────────────────────────────────────────────
#
# No OpenAI key needed. The LLM brain runs server-side on the rebalancer
# using Claude Code subscription auth — the Pi just sends transcripts and
# receives text replies. Only STT (speech → text) and TTS (text → speech)
# run locally on the Pi, both via ElevenLabs.

# ElevenLabs API key — used for Scribe STT, TTS, and voice isolation.
ELEVENLABS_API_KEY=

# ElevenLabs voice ID for Bablu's voice. Pick from elevenlabs.io/app/voice-library
# or reuse one you already trained.
ELEVENLABS_VOICE_ID=

# Conversation thread id on the rebalancer. Stable across turns so history
# carries over. Change if you run multiple voice devices against one
# rebalancer and want them in separate threads.
VOICE_CHAT_ID=voice-bablu

# ── Optional tuning ────────────────────────────────────────────────

# Wake-word fuzzy threshold (0..1). Lower = easier to wake, more false fires.
# Set to 0 to always-listen without a wake word.
WAKE_THRESHOLD=0.55

# Seconds after Bablu speaks during which wake-word gate is bypassed (lets
# the user have a natural follow-up without re-saying "Bablu").
FOLLOW_UP_SECONDS=60

# Pre-STT voice isolator. 1 to enable (strips fan/AC noise), 0 to disable.
BABLU_USE_ISOLATOR=1

# WebSocket port the Chromium kiosk connects to for face updates.
FACE_WEBSOCKET_PORT=7780

# Log verbosity.
LOG_LEVEL=INFO
